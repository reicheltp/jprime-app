# SQLite path (local dev default). Switch to a postgres:// URL for production.
DATABASE_PATH=./jprime-auth.db

# SMTP — leave SMTP_HOST empty to skip sending and log OTPs to stdout instead.
# For local dev, run Mailpit: https://github.com/axllent/mailpit
#   brew install mailpit  (or: go install github.com/axllent/mailpit@latest)
#   mailpit  →  SMTP on :1025, web UI on http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@jprime.io
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# JWT signing secret — MUST be changed in production
JWT_SECRET=dev-secret-change-in-production

# Return the OTP code in the API response (dev/test only — never enable in production)
OTP_EXPOSE_IN_RESPONSE=true
