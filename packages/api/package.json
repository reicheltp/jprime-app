{
  "name": "@jprime/api",
  "version": "0.0.1",
  "description": "API clients and React Query hooks for JPrime Conference App",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "18.2.0"
  },
  "devDependencies": {
    "@types/react": "~18.2.45",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bun": {
    "exports": {
      ".": "./dist/index.js",
      "./clients/*": "./dist/clients/*.js",
      "./queries/*": "./dist/queries/*.js",
      "./types/*": "./dist/types/*.js"
    }
  }
}
