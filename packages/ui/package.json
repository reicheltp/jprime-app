{
  "name": "@jprime/ui",
  "version": "0.0.1",
  "description": "Shared UI components for JPrime Conference App",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.73.2",
    "nativewind": "^4.0.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0",
    "@jprime/types": "workspace:*",
    "@jprime/utils": "workspace:*",
    "@jprime/api": "workspace:*",
    "@react-native-async-storage/async-storage": "^3.1.1"
  },
  "devDependencies": {
    "@types/react": "~18.2.45",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bun": {
    "exports": {
      ".": "./dist/index.js",
      "./components/*": "./dist/components/*.js"
    }
  }
}
