{
  "name": "@jprime/utils",
  "version": "0.0.1",
  "description": "Shared utilities for JPrime Conference App",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "react": "18.2.0"
  },
  "devDependencies": {
    "@types/react": "~18.2.45",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bun": {
    "exports": {
      ".": "./dist/index.js",
      "./constants/*": "./dist/constants/*.js",
      "./helpers/*": "./dist/helpers/*.js"
    }
  }
}
