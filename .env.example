# Supabase — required for auth (SPEC-006)
# Cloud: copy from https://app.supabase.com → Project Settings → API
# Self-hosted: your own Supabase instance URL + anon key (no code changes needed)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Conference API
EXPO_PUBLIC_API_URL=http://localhost:3000
